# העתיקי לקובץ `azure.env` (אותו תיקייה — הקובץ azure.env ב-.gitignore ולא עולה ל-git).
# בכל חלון PowerShell לפני הרצת מנועים:
#   Set-Location <נתיב-לתיקיית-Formulix>
#   . .\scripts\Apply-AzureEnv.ps1
#
# מחרוזות מ-Azure Portal → SQL Database → Connection strings (ADO.NET / ODBC).
# ודאי ש-Firewall של Azure SQL כולל את ה-IP של המחשב שלך.

FORMULIX_DB_CONNECTION=Server=tcp:YOURSERVER.database.windows.net,1433;Initial Catalog=FormulixDB;User ID=YOURUSER;Password=YOUR_PASSWORD;Encrypt=True;TrustServerCertificate=False;Connection Timeout=300;

FORMULIX_DB_ODBC=DRIVER={ODBC Driver 17 for SQL Server};SERVER=tcp:YOURSERVER.database.windows.net,1433;DATABASE=FormulixDB;UID=YOURUSER;PWD=YOUR_PASSWORD;Encrypt=yes;TrustServerCertificate=no;Connection Timeout=300;
