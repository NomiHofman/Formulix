# Formulix Dashboard Environment Variables
# Copy this file to .env and update the values
# Do NOT commit .env (it is in .gitignore).

# Vite: optional override when calling a remote .NET API (local dev: Formulix.API on Kestrel)
# For production: https://formulix-api.azurewebsites.net
VITE_API_URL=http://localhost:5000

# Vercel serverless routes under /api (summary, optimize, …) need Azure SQL credentials.
# Set these in Vercel → Project → Settings → Environment Variables (not in git).
# AZURE_SQL_SERVER=yourserver.database.windows.net
# AZURE_SQL_DATABASE=FormulixDB
# AZURE_SQL_USER=youruser
# AZURE_SQL_PASSWORD=yourpassword
